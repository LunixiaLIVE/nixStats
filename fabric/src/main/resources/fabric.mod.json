{
  "schemaVersion": 1,
  "id": "nixstats",
  "version": "${version}",
  "name": "nixStats",
  "description": "Configurable stat sidebar HUD. Track phantom timer, blocks mined, entities killed, and any other Minecraft statistic.",
  "authors": ["LunixiaLIVE"],
  "contact": {
    "homepage": "https://github.com/LunixiaLIVE/Lunixia-Minecraft-QOL-Mods",
    "sources": "https://github.com/LunixiaLIVE/nixStats"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": ["net.lunix.nixstats.fabric.NixStatsFabric"]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "26.1.x"
  }
}
